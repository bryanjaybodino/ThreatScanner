{
  "manifest_version": 3,
  "name": "BotAutoFill",
  "version": "1.0.0",
  "description": "Dynamically fills any form fields with realistic data — mirrors the Playwright BotAutoFill bot.",
  "permissions": [ "activeTab", "scripting", "storage" ],
  "host_permissions": [ "<all_urls>" ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [ "<all_urls>" ],
      "js": [ "content.js" ],
      "run_at": "document_idle"
    }
  ]
}